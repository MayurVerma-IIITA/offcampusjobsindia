generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum JobStatus {
  DRAFT
  PUBLISHED
  EXPIRED
  ARCHIVED
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ExperienceLevel {
  FRESHER
  EXPERIENCED
  ANY
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  jobs         Job[]
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  website   String?
  about     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  jobs        Job[]
}

model Location {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  state     String?
  jobs      Job[]
}

model Qualification {
  id   String @id @default(cuid())
  name String
  slug String @unique
  jobs JobQualification[]
}

model Batch {
  id   String @id @default(cuid())
  year String
  slug String @unique
  jobs JobBatch[]
}

model Job {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  companyId       String
  locationId      String
  categoryId      String
  workMode        WorkMode
  experienceLevel ExperienceLevel @default(ANY)
  salary          String?
  deadline        DateTime?
  applyUrl        String
  featuredImage   String?
  seoTitle        String
  metaDescription String
  excerpt         String
  articleContent  String
  status          JobStatus       @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  authorId        String?

  author         User?              @relation(fields: [authorId], references: [id])
  company        Company            @relation(fields: [companyId], references: [id])
  location       Location           @relation(fields: [locationId], references: [id])
  category       Category           @relation(fields: [categoryId], references: [id])
  qualifications JobQualification[]
  batches        JobBatch[]
  analytics      AnalyticsEvent[]

  @@index([status, publishedAt])
  @@index([companyId])
  @@index([locationId])
  @@index([categoryId])
  @@index([workMode])
  @@index([authorId])
}

model JobQualification {
  jobId           String
  qualificationId String
  job             Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)

  @@id([jobId, qualificationId])
  @@index([qualificationId])
}

model JobBatch {
  jobId   String
  batchId String
  job     Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@id([jobId, batchId])
  @@index([batchId])
}

model Article {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String
  content         String
  seoTitle        String
  metaDescription String
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  path      String?
  jobId     String?
  metadata  Json?
  createdAt DateTime @default(now())
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([jobId])
}
